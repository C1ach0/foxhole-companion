{
  "name": "foxpile-companion",
  "productName": "Foxpile Companion",
  "version": "1.1.0",
  "description": "Foxpile Companion watches Foxhole save files and syncs metadata to the Foxpile API",
  "license": "ISC",
  "author": "C1ach0",
  "type": "module",
  "main": "index.ts",
  "bin": "index.ts",
  "scripts": {
    "start": "tsx index.ts",
    "dev": "tsx index.ts --debug",
    "build": "npm run build:windows",
    "build:windows": "node tools/build-windows.js",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6",
    "rcedit": "^5.0.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "minimist": "^1.2.8",
    "open": "^11.0.0",
    "systray2": "^2.1.4"
  }
}
